[postgres2]
enabled = true
createTable = """
  CREATE TABLE IF NOT EXISTS "%s" (
    dirhash   BIGINT,
    name      VARCHAR(65535),
    directory VARCHAR(65535),
    meta      bytea,
    PRIMARY KEY (dirhash, name)
  );
"""
hostname = "pg.internal"
port = 5432
username = "seaweed"
password = "s3cret"
database = "seaweedfs"
schema = "public"
sslmode = "disable"
connection_max_idle = 2
connection_max_open = 100
connection_max_lifetime_seconds = 0
